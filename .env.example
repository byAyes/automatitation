# Gmail API OAuth2 Credentials
# ⚠️  YOU MUST SET THESE BEFORE RUNNING THE AUTOMATION
# 
# To get these values:
# 1. Go to: https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Gmail API (Library → Search "Gmail API" → Enable)
# 4. Go to "Credentials" → "Create Credentials" → "OAuth 2.0 Client ID"
# 5. Application type: "Web application"
# 6. Add authorized redirect URI: http://localhost:3000/oauth2callback
# 7. Copy Client ID and Client Secret below

GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Email recipient for job digests
GMAIL_RECIPIENT=your_email@example.com

# OAuth2 Tokens (DO NOT EDIT THESE MANUALLY)
# These will be automatically populated after you run:
# npx tsx scripts/setup-gmail-auth.ts
# GMAIL_ACCESS_TOKEN=
# GMAIL_REFRESH_TOKEN=

# JSearch API Key (for job scraping)
# Get from: https://rapidapi.com/letscrape/api/jsearch
JSEARCH_API_KEY=your_jsearch_api_key_here

# OpenAI API Key (for job matching)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
