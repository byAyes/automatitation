# =============================================================================
# Seahorse — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: .env is in .gitignore — it will NOT be committed.
# =============================================================================


# ─── Jina Reader (Self-hosted or Cloud) ─────────────────────────────────────
# Jina Reader acts as a headless Chrome proxy for JS-rendered job sites.
# Default: https://r.jina.ai (cloud — rate-limited, blocks LinkedIn)
# When self-hosting with Docker, point to your local instance:
#   docker compose up -d jina-reader
#   JINA_READER_BASE_URL=http://localhost:3001
# JINA_READER_BASE_URL=


# ─── Computrabajo Scraper ───────────────────────────────────────────────────
# Country code for Computrabajo (e.g., co, mx, ar, es, pe, cl)
# Default: co
# COMPUTRABAJO_COUNTRY=

# Custom base URL for Computrabajo (overrides auto-generated URL)
# Default: https://{country}.computrabajo.com
# COMPUTRABAJO_BASE_URL=


# ─── Job Search (JSearch API) ───────────────────────────────────────────────
# Required for job scraping via the JSearch API on RapidAPI.
# Sign up: https://rapidapi.com/letscrape/api/jsearch
JSEARCH_API_KEY=your_jsearch_api_key_here

# Query and pagination defaults for the pipeline
# JOB_QUERY=software engineer
# JOB_LOCATION=
# MAX_JOBS_PER_SCRAPER=10
# JOB_DAYS_FILTER=3
# SCRAPE_QUERY=software developer
# SCRAPE_MAX_JOBS=20


# ─── AI / LLM Provider ─────────────────────────────────────────────────────
# Gemini is the primary AI provider (profile extraction, matching, scraping)
# Get a free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative/fallback providers:
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# NIM_API_KEY=


# ─── Email Provider Selection ───────────────────────────────────────────────
# Options: smtp (default), gmail, sendgrid, resend
# EMAIL_PROVIDER=smtp

# SMTP (default — recommended, works with Gmail App Passwords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
# SMTP_FROM=your_email@gmail.com

# Gmail API (if EMAIL_PROVIDER=gmail)
# Requires OAuth2 setup: npx tsx scripts/setup-gmail-auth.ts
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Resend (if EMAIL_PROVIDER=resend)
# Sign up: https://resend.com
# RESEND_API_KEY=your_resend_api_key_here
# RESEND_FROM_EMAIL=onboarding@resend.dev

# SendGrid (if EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=


# ─── Email Recipients ───────────────────────────────────────────────────────
# Required: who receives the daily job digest
GMAIL_RECIPIENT=your_email@example.com

# Optional: CC recipient for digests
# EMAIL_CC=

# Alternative recipient env var (used by send-email-digest.ts)
# DIGEST_RECIPIENT_EMAIL=


# ─── Development ────────────────────────────────────────────────────────────
# NODE_ENV=development
