# Email Provider Selection
# Options: gmail, sendgrid, smtp, resend
# Default: gmail (requires OAuth2 setup)
EMAIL_PROVIDER=gmail

# Gmail Configuration (if EMAIL_PROVIDER=gmail)
# ⚠️  REQUIRES OAUTH2 SETUP - Run: npx tsx scripts/setup-gmail-auth.ts
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GMAIL_RECIPIENT=your_email@example.com

# SendGrid Configuration (if EMAIL_PROVIDER=sendgrid)
# Get API key from: https://app.sendgrid.com/settings/api_keys
# Free tier: 100 emails/day
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_automation@example.com

# SMTP Configuration (if EMAIL_PROVIDER=smtp)
# Use any SMTP provider or Gmail with App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_automation@gmail.com
# For Gmail: Use App Password (not regular password)
# Get App Password: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=your_automation@gmail.com

# Resend Configuration (if EMAIL_PROVIDER=resend)
# Modern email API: https://resend.com
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# JSearch API Key (for job scraping)
# Get from: https://rapidapi.com/letscrape/api/jsearch
JSEARCH_API_KEY=your_jsearch_api_key_here

# OpenAI API Key (for job matching)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
